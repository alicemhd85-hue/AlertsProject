@model List<Usersinfo>
@{
    ViewData["Title"] = "Home Page";
    
}

<!-- Google Font -->
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;700&display=swap" rel="stylesheet">

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        font-family: 'Tajawal', sans-serif;
        margin: 0;
        background: url('https://images.unsplash.com/photo-1581090700227-4c4f50b9f0c1') no-repeat center center/cover;
        height: 100vh;
    }

    /* طبقة شفافة */
    .overlay {
        background: rgba(0, 0, 0, 0.6);
        min-height: 100vh;
        padding: 40px 0;
    }

    /* الهيدر */
    .header-box {
        background: rgba(255, 255, 255, 0.95);
        padding: 20px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
    }

    /* الكروت */
    .card {
        transition: 0.3s;
        backdrop-filter: blur(5px);
    }

        .card:hover {
            transform: translateY(-5px);
        }

    /* الأزرار */
    .btn-dark {
        background: linear-gradient(135deg, #1f1f1f, #343a40);
        border: none;
    }

        .btn-dark:hover {
            opacity: 0.9;
        }

    .btn-success {
        border-radius: 10px;
        padding: 10px 20px;
    }

    input.form-control {
        border-radius: 10px;
        padding: 10px;
    }
</style>

<div class="overlay">

    <!-- Header -->
    <div class="text-center mb-5 container header-box">
        <h1 class="fw-bold">توصيف المشاكل التي تواجه المستخدم أثناء التصفح</h1>
        <p class="text-muted">(SSL/TLS) نظام ذكي لتحليل اخطاء الاتصال الحرجة و القاتلة</p>
    </div>

    <!-- Content -->
    <div class="container mt-4">
        <div class="row text-center g-4">

            <!-- Card 1 -->
            <div class="col-md-6">
                <div class="card shadow-lg h-100 border-0 rounded-4 p-4 text-center bg-white">

                    <p>alerts code تحديد الاخطاء بالكود</p>

                    <form asp-action="Search" method="post">
                        <div class="form-group">
                            <label for="errorCode">Enter Error Code:</label>
                            <input type="text" id="errorCode" name="errorCode" class="form-control" placeholder="Error Code" />
                        </div>

                        <button type="submit" class="btn btn-dark w-100 rounded-3 mt-3">
                            ابدأ البحث الآن
                        </button>
                    </form>

                </div>
            </div>

            <!-- Card 2 -->
            <div class="col-md-6">
                <div class="card shadow-lg h-100 border-0 rounded-4 p-4 text-center bg-white">

                    <p class="text-muted">alerts name اكتشاف الاخطاء بالاسم</p>

                    <form asp-action="Searchusingname" method="post">
                        <div class="form-group">
                            <label for="codename">Enter Error Name:</label>
                            <input type="text" id="codename" name="codename" class="form-control" placeholder="Error Name" />
                        </div>

                        <button type="submit" class="btn btn-dark w-100 rounded-3 mt-3">
                            ابدأ البحث الآن
                        </button>
                    </form>

                </div>
            </div>

            <!-- Button -->
            <div class="text-center mt-4">
                <a asp-action="Create" class="btn btn-success px-4 py-2 rounded-3 shadow">
                    ➕ إضافة إلى قاعدة البيانات
                </a>
            </div>

            <div class="container mt-4">
                <div class="row">

                    <!-- العمود الأول: الفورم -->
                    <div class="col-md-6">
                        <div class="card p-4 shadow rounded-4">
                            <h5>إضافة مستخدم</h5>

                            <form asp-action="AddUser" method="post">

                                <div class="mb-3">
                                    <label class="form-label">اسم المستخدم</label>
                                    <input type="text" name="UserName" class="form-control" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">البريد الإلكتروني</label>
                                    <input type="email" name="Email" class="form-control" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">الدولة</label>
                                    <input type="text" name="Country" class="form-control" />
                                </div>

                                <button type="submit" class="btn btn-primary w-100">
                                    إضافة المستخدم
                                </button>

                                <button type="button" id="toggleBtn" class="btn btn-secondary w-100 mt-2">
                                    إظهار المستخدمين
                                </button>

                            </form>
                        </div>
                    </div>

                    <!-- العمود الثاني: الجدول -->
                    <div class="col-md-6">
                        <div id="usersTable" class="card p-4 shadow rounded-4" style="display:none;">
                            <h5>قائمة المستخدمين</h5>

                            @if (Model != null && Model.Count > 0)
                            {
                                <table class="table table-bordered">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>الاسم</th>
                                            <th>الإيميل</th>
                                            <th>الدولة</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.Count; i++)
                                        {
                                            <tr>
                                                <td>@(i + 1)</td>
                                                <td>@Model[i].UserName</td>
                                                <td>@Model[i].Email</td>
                                                <td>@Model[i].Country</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <p>لا توجد بيانات</p>
                            }
                        </div>
                    </div>

                </div>
            </div>

            <script>
                document.getElementById("toggleBtn").onclick = function () {
                    var table = document.getElementById("usersTable");

                    if (table.style.display === "none") {
                        table.style.display = "block";
                        this.innerText = "إخفاء المستخدمين";
                    } else {
                        table.style.display = "none";
                        this.innerText = "إظهار المستخدمين";
                    }
                };
            </script>
